# MemCore configuration (copy to .env for local dev).
# All variables are prefixed MEMCORE_ and mapped via pydantic-settings.

# --- App ---
MEMCORE_ENV=local
MEMCORE_LOG_LEVEL=INFO
MEMCORE_LOG_JSON=false

# --- Working memory (Redis) ---
MEMCORE_REDIS__URL=redis://localhost:6379/0
MEMCORE_REDIS__SESSION_TTL_SECONDS=3600
MEMCORE_REDIS__BUFFER_MAX_TURNS=200

# --- Vector store (Qdrant, default) ---
MEMCORE_VECTOR__PROVIDER=qdrant
MEMCORE_VECTOR__URL=http://localhost:6333
MEMCORE_VECTOR__API_KEY=

# --- Graph store (Neo4j) ---
MEMCORE_GRAPH__URL=bolt://localhost:7687
MEMCORE_GRAPH__USER=neo4j
MEMCORE_GRAPH__PASSWORD=memcore-dev-password

# --- Embeddings (default bge-small; pluggable) ---
MEMCORE_EMBEDDING__PROVIDER=bge
MEMCORE_EMBEDDING__MODEL=BAAI/bge-small-en-v1.5
MEMCORE_EMBEDDING__DIMENSION=384
MEMCORE_EMBEDDING__API_KEY=

# --- Retrieval engine knobs (defaults shown; see RetrievalSettings) ---
MEMCORE_RETRIEVAL__LEXICAL_ALPHA=0.3
MEMCORE_RETRIEVAL__GRAPH_EXPAND=true
MEMCORE_RETRIEVAL__GRAPH_MAX_HOPS=2
MEMCORE_RETRIEVAL__CONTEXT_TOKEN_BUDGET=2000

# --- Consolidation LLM (Claude Sonnet primary, Ollama fallback) ---
MEMCORE_LLM__PROVIDER=anthropic
MEMCORE_LLM__MODEL=claude-sonnet-5
MEMCORE_LLM__FALLBACK_PROVIDER=ollama
MEMCORE_LLM__FALLBACK_MODEL=llama3.1
MEMCORE_LLM__API_KEY=
MEMCORE_LLM__OLLAMA_URL=http://localhost:11434

# --- Consolidation knobs ---
MEMCORE_CONSOLIDATION__DUP_SIMILARITY=0.9
MEMCORE_CONSOLIDATION__CONFLICT_CONFIDENCE=0.7

# --- Scheduler (Celery default; Temporal optional/future) ---
MEMCORE_SCHEDULER__PROVIDER=celery
MEMCORE_SCHEDULER__BROKER_URL=redis://localhost:6379/1

# --- Metadata database (source of truth; Postgres prod, SQLite dev) ---
MEMCORE_DATABASE__PROVIDER=sql
MEMCORE_DATABASE__URL=postgresql+asyncpg://memcore:memcore@localhost:5432/memcore

# --- API auth: JSON map of api-key -> tenant. Empty + env=local injects dev-key.
MEMCORE_API__KEYS={}
